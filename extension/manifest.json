{
    "manifest_version": 3,
    "name": "Formitra AI Assistant",
    "version": "1.0",
    "description": "AI-assisted form filler for public service portals.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "unlimitedStorage",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Formitra AI Assistant"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}